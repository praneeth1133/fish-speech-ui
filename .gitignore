# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# legacy local-only data dir from the SQLite/disk era — no longer used
/data

# VCTK parquet shards — downloaded on demand by scripts/vctk-work/extract_and_register.py
# Too large (2+ GB) to commit. The generated WAV samples go to scripts/vctk-work/voices/
# which we also skip (they're one-time fixtures for backend registration, not runtime assets)
/scripts/vctk-work/shard*.parquet
/scripts/vctk-work/voices/
/scripts/vctk-work/manifest.urls
